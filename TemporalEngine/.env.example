# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Kafka / Redpanda ──────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:19092          # external port exposed by docker-compose

# ── Graph DB (Memgraph) ───────────────────────────────────────────────────────
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# ── Feature Store (Redis) ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Data Lake (MinIO / Iceberg) ───────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password
WAREHOUSE_PATH=s3://warehouse

# ── Flink ─────────────────────────────────────────────────────────────────────
JAR_PATH=lib/iceberg-flink-runtime-1.18-1.5.2.jar

# ── Ring Hunter ───────────────────────────────────────────────────────────────
CHECK_INTERVAL=15                     # seconds between fraud-ring scans
