{
  "manifest_version": 3,
  "name": "CommitGlow: Material Edition",
  "version": "4.0.0",
  "description": "Premium New Tab featuring GitHub contributions and Material You design.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "bookmarks",
    "favicon",
    "search"
  ],
  "optional_host_permissions": [
    "https://www.google.com/complete/search?client=*",
    "https://duckduckgo.com/ac/?q=*",
    "https://search.brave.com/api/suggest?q=*",
    "https://*.wikipedia.org/w/api.php?action=opensearch&search=*"
  ],
  "action": {
    "default_popup": "options.html",
    "default_icon": "favicon/icon48.png"
  },
  "options_page": "options.html",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "lib/github-calendar.min.js",
        "content.js"
      ],
      "css": [
        "lib/github-calendar-responsive.css"
      ],
      "run_at": "document_idle",
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "favicon/*",
        "styles.css",
        "lib/*",
        "newtab-glow.js"
      ]
    }
  ],
  "incognito": "split"
}
